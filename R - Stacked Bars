# SUM OF SQUARES ANALYSIS FOR RELATIVE ABUNDANCE
# ------------------------------------------------------------------------------

# Calculate mean relative abundance for each guild across all samples
guild_means <- abundance_summary %>%
  group_by(Guild) %>%
  summarise(Mean_Relative_Abundance = mean(Relative_Abundance),
            .groups = "drop")

# Calculate Total Sum of Squares (TSS)
# This measures total variation in relative abundance across all samples and guilds
grand_mean <- mean(abundance_summary$Relative_Abundance)
TSS <- sum((abundance_summary$Relative_Abundance - grand_mean)^2)

# Calculate Between-Group Sum of Squares (BSS)
# This measures variation between guilds (how different guild means are from grand mean)
abundance_with_means <- abundance_summary %>%
  left_join(guild_means, by = "Guild")

BSS <- sum((abundance_with_means$Mean_Relative_Abundance - grand_mean)^2)

# Calculate Within-Group Sum of Squares (WSS)
# This measures variation within each guild (how samples vary within each guild)
WSS <- sum((abundance_with_means$Relative_Abundance - 
              abundance_with_means$Mean_Relative_Abundance)^2)

# Calculate proportion of variance explained by guild classification
R_squared <- BSS / TSS

# Create summary table
ss_summary_abundance <- data.frame(
  Source = c("Between Guilds (BSS)", "Within Guilds (WSS)", "Total (TSS)"),
  Sum_of_Squares = c(BSS, WSS, TSS),
  Proportion_of_Total = c(BSS/TSS, WSS/TSS, 1.0),
  Percentage = c(BSS/TSS * 100, WSS/TSS * 100, 100)
)

# Calculate sum of squares for each individual guild
guild_ss_abundance <- abundance_summary %>%
  left_join(guild_means, by = "Guild") %>%
  group_by(Guild) %>%
  summarise(
    Mean_Relative_Abundance = first(Mean_Relative_Abundance),
    Within_Guild_SS = sum((Relative_Abundance - Mean_Relative_Abundance)^2),
    N_Samples = n(),
    Variance = Within_Guild_SS / (N_Samples - 1),
    Std_Dev = sqrt(Variance),
    .groups = "drop"
  ) %>%
  arrange(desc(Mean_Relative_Abundance))

# Add contribution to total variation
guild_ss_abundance <- guild_ss_abundance %>%
  mutate(
    Percent_of_WSS = Within_Guild_SS / WSS * 100,
    CV = (Std_Dev / Mean_Relative_Abundance) * 100  # Coefficient of variation
  )

# Print results to console
cat("\n=== SUM OF SQUARES ANALYSIS - RELATIVE ABUNDANCE ===\n")
cat("\nOverall Variation Decomposition:\n")
print(ss_summary_abundance, row.names = FALSE)
cat("\nR-squared (proportion of variance explained by guilds):", 
    round(R_squared, 4), "\n")
cat("\nInterpretation:")
cat("\n  - Between-group variation (BSS) represents how different the guilds are from each other")
cat("\n  - Within-group variation (WSS) represents variation among samples within each guild")
cat("\n  - R-squared shows what proportion of total variation is explained by guild identity\n")

cat("\n\nGuild-Specific Variation:\n")
print(guild_ss_abundance, row.names = FALSE)
cat("\nInterpretation:")
cat("\n  - Within_Guild_SS: Total variation within that guild")
cat("\n  - Std_Dev: Standard deviation of relative abundance for that guild")
cat("\n  - CV: Coefficient of variation (higher = more variable across samples)")
cat("\n  - Percent_of_WSS: This guild's contribution to within-group variation\n")

