# ==============================================================================
# STACKED BAR CHARTS FOR OTU GUILD ANALYSIS
# ==============================================================================
# This script creates fourteen stacked bar charts:
# GUILD ANALYSIS:
# 1. Abundance-based: Shows relative abundance of each guild per sample
# 2. Richness-based: Shows number of OTUs from each guild per sample
# 3. Occurrence-based (relative): Shows proportion of OTUs from each guild per sample
# 4. Total abundance (absolute): Shows total read counts per guild per sample
# PHYLUM ANALYSIS:
# 9. Relative abundance by phylum
# 10. Absolute abundance by phylum
# 11. Relative occurrence by phylum
# 12. Absolute occurrence by phylum
# ==============================================================================

# ------------------------------------------------------------------------------
# LOAD REQUIRED LIBRARIES
# ------------------------------------------------------------------------------
library(biomformat)  # For reading .biom files
library(tidyverse)   # For data manipulation and ggplot2
library(reshape2)    # For data reshaping

# ------------------------------------------------------------------------------
# READ INPUT FILES
# ------------------------------------------------------------------------------

# Read the OTU table from BIOM format
# BIOM files are a standard format for biological observation matrices
otu_biom <- read_biom("~/Downloads/FenData/R Studio/FENS.ITS.StkBr.wG.wPhy_20260210/data/OTU.biom")

# Extract the OTU table as a matrix (OTUs as rows, samples as columns)
otu_table <- as.matrix(biom_data(otu_biom))

# Convert to data frame and add OTU_ID as a column
otu_df <- as.data.frame(otu_table)
otu_df$OTU_ID <- rownames(otu_df)

# Read guild metadata (links each OTU to its functional guild)
guild_metadata <- read.csv("~/Downloads/FenData/R Studio/FENS.ITS.StkBr.wG.wPhy_20260210/data/guild_metadata.csv", stringsAsFactors = FALSE)

# Read sample metadata (contains Field.ID labels for samples)
sample_metadata <- read.csv("~/Downloads/FenData/R Studio/FENS.ITS.StkBr.wG.wPhy_20260210/data/sample_metadata.csv", stringsAsFactors = FALSE)

# extract OTU taxonomy from BIOM file
tax_data <- observation_metadata(otu_biom)

# create phylum dataframe
phylum_df <- data.frame(
  OTU_ID = row.names(tax_data),
  Phylum = tax_data$taxonomy2
)
# clean Phylum Values
phylum_df$Phylum <- gsub("p__", "", as.character(phylum_df$Phylum))

# filter for fungi
phylum_df <- phylum_df %>% 
  filter(grepl("Ascomycota|Basidiomycota|Chytridiomycota|
                Mucuromycota|Rozellomycota|Monoblepharomycota|Cercozoa|
                Olpidiomycota|Entorrhizomycota|Katablepharidophyta|
                Basidiobolomycota|Glomeromycota|Mortierellomycota|
                Fungi_phy_Incertae_sedis|Blastocladiomycota|
                Aphelidiomycota|Zoopagomycota|Kickxellomycota", Phylum)
         )

# ------------------------------------------------------------------------------
# DATA VALIDATION AND CLEANING
# ------------------------------------------------------------------------------

# Ensure guild values are standardized (remove extra whitespace)
guild_metadata$Guild <- trimws(guild_metadata$Guild)

# Verify unique guild values
print(unique(guild_metadata$Guild))

# Verify that all guild values are valid
valid_guilds <- c("Endophyte", "Saprotroph", "Saprotroph-Symbiotroph", 
                  "Pathogen-Saprotroph", "Pathogen", "Endomycorrhizal", 
                  "Ectomycorrhizal", "Epiphyte-Saprotroph", "Lichenized", "Other")

if (!all(guild_metadata$Guild %in% valid_guilds)) {
  warning("Some guild values do not match expected categories!")
}

# ------------------------------------------------------------------------------
# MERGE OTU DATA WITH GUILD INFORMATION
# ------------------------------------------------------------------------------

# Join OTU table with guild metadata to assign guilds to each OTU
otu_with_guild <- otu_df %>%
  left_join(guild_metadata, by = "OTU_ID")

# Remove OTUs without guild assignment
otu_with_guild <- otu_with_guild %>%
  filter(!is.na(Guild))

# Create separate dataset for phylum analysis
otu_with_phylum <- otu_df %>%
  left_join(phylum_df, by = "OTU_ID")
# again filter for fungi
otu_with_phylum <- otu_with_phylum %>%
  filter(!is.na(Phylum))

# ------------------------------------------------------------------------------
# PREPARE DATA FOR ABUNDANCE-BASED CHART (ALL GUILDS)
# ------------------------------------------------------------------------------

# Reshape data from wide to long format for ggplot
# This converts sample columns into rows
otu_long <- otu_with_guild %>%
  pivot_longer(cols = -c(OTU_ID, Guild), 
               names_to = "SampleID", 
               values_to = "Abundance")

# Calculate total abundance for each guild in each sample
abundance_summary <- otu_long %>%
  group_by(SampleID, Guild) %>%
  summarise(Total_Abundance = sum(Abundance), .groups = "drop")

# Calculate relative abundance (proportions) within each sample
abundance_summary <- abundance_summary %>%
  group_by(SampleID) %>%
  mutate(Relative_Abundance = Total_Abundance / sum(Total_Abundance) * 100) %>%
  ungroup()

# ------------------------------------------------------------------------------
# PREPARE DATA FOR RICHNESS-BASED CHART (ALL GUILDS)
# ------------------------------------------------------------------------------

# Richness = count of unique OTUs present (abundance > 0) per guild per sample
otu_richness <- otu_long %>%
  filter(Abundance > 0) %>%  # Only count OTUs that are present
  group_by(SampleID, Guild) %>%
  summarise(OTU_Richness = n(), .groups = "drop")  # Count unique OTUs

# Note: This is the absolute richness (count), not relative
# We keep it as counts for the stacked bar chart

# ------------------------------------------------------------------------------
# PREPARE DATA FOR OCCURRENCE-BASED CHART (ALL GUILDS)
# ------------------------------------------------------------------------------

# For occurrence, we only care if an OTU is present (>0), not its abundance
otu_occurrence <- otu_long %>%
  mutate(Present = ifelse(Abundance > 0, 1, 0))

# Count number of OTUs from each guild present in each sample
occurrence_summary <- otu_occurrence %>%
  group_by(SampleID, Guild) %>%
  summarise(OTU_Count = sum(Present), .groups = "drop")

# Calculate proportion of OTUs from each guild within each sample
occurrence_summary <- occurrence_summary %>%
  group_by(SampleID) %>%
  mutate(Relative_Occurrence = OTU_Count / sum(OTU_Count) * 100) %>%
  ungroup()

# ------------------------------------------------------------------------------
# ADD Field.ID LABELS TO ALL DATASETS
# ------------------------------------------------------------------------------

# Match SampleID to Field.ID for better labeling on charts
abundance_summary <- abundance_summary %>%
  left_join(sample_metadata %>% select(SampleID, `Field.ID`), 
            by = "SampleID")

otu_richness <- otu_richness %>%
  left_join(sample_metadata %>% select(SampleID, `Field.ID`), 
            by = "SampleID")

occurrence_summary <- occurrence_summary %>%
  left_join(sample_metadata %>% select(SampleID, `Field.ID`), 
            by = "SampleID")

abundance_summary_no_other <- abundance_summary_no_other %>%
  left_join(sample_metadata %>% select(SampleID, `Field.ID`), 
            by = "SampleID")

otu_richness_no_other <- otu_richness_no_other %>%
  left_join(sample_metadata %>% select(SampleID, `Field.ID`), 
            by = "SampleID")

occurrence_summary_no_other <- occurrence_summary_no_other %>%
  left_join(sample_metadata %>% select(SampleID, `Field.ID`), 
            by = "SampleID")

# Use Field.ID if available, otherwise use SampleID
abundance_summary <- abundance_summary %>%
  mutate(Label = ifelse(!is.na(`Field.ID`), `Field.ID`, SampleID))

otu_richness <- otu_richness %>%
  mutate(Label = ifelse(!is.na(`Field.ID`), `Field.ID`, SampleID))

occurrence_summary <- occurrence_summary %>%
  mutate(Label = ifelse(!is.na(`Field.ID`), `Field.ID`, SampleID))

abundance_summary_no_other <- abundance_summary_no_other %>%
  mutate(Label = ifelse(!is.na(`Field.ID`), `Field.ID`, SampleID))

otu_richness_no_other <- otu_richness_no_other %>%
  mutate(Label = ifelse(!is.na(`Field.ID`), `Field.ID`, SampleID))

occurrence_summary_no_other <- occurrence_summary_no_other %>%
  mutate(Label = ifelse(!is.na(`Field.ID`), `Field.ID`, SampleID))

# ------------------------------------------------------------------------------
# PREPARE DATA FOR PHYLUM ANALYSIS
# ------------------------------------------------------------------------------

# Reshape phylum data from wide to long format
otu_phylum_long <- otu_with_phylum %>%
  pivot_longer(cols = -c(OTU_ID, Phylum), 
               names_to = "SampleID", 
               values_to = "Abundance")

# Calculate total abundance for each phylum in each sample
phylum_abundance_summary <- otu_phylum_long %>%
  group_by(SampleID, Phylum) %>%
  summarise(Total_Abundance = sum(Abundance), .groups = "drop")

# Calculate relative abundance (proportions) within each sample
phylum_abundance_summary <- phylum_abundance_summary %>%
  group_by(SampleID) %>%
  mutate(Relative_Abundance = Total_Abundance / sum(Total_Abundance) * 100) %>%
  ungroup()

# Calculate occurrence for phylum
otu_phylum_occurrence <- otu_phylum_long %>%
  mutate(Present = ifelse(Abundance > 0, 1, 0))

phylum_occurrence_summary <- otu_phylum_occurrence %>%
  group_by(SampleID, Phylum) %>%
  summarise(OTU_Count = sum(Present), .groups = "drop")

# Calculate relative occurrence
phylum_occurrence_summary <- phylum_occurrence_summary %>%
  group_by(SampleID) %>%
  mutate(Relative_Occurrence = OTU_Count / sum(OTU_Count) * 100) %>%
  ungroup()

# Add Field.ID labels to phylum datasets
phylum_abundance_summary <- phylum_abundance_summary %>%
  left_join(sample_metadata %>% select(SampleID, `Field.ID`), by = "SampleID") %>%
  mutate(Label = ifelse(!is.na(`Field.ID`), `Field.ID`, SampleID))

phylum_occurrence_summary <- phylum_occurrence_summary %>%
  left_join(sample_metadata %>% select(SampleID, `Field.ID`), by = "SampleID") %>%
  mutate(Label = ifelse(!is.na(`Field.ID`), `Field.ID`, SampleID))

