  "Saprotroph" = "#ff7f0e",             # Orange
  "Saprotroph-Symbiotroph" = "#2ca02c", # Green
  "Pathogen-Saprotroph" = "#d62728",    # Red
  "Pathogen" = "#9467bd",               # Purple
  "Endomycorrhizal" = "#8c564b",        # Brown
  "Ectomycorrhizal" = "#e377c2",        # Pink
  "Lichenized" = "#bcbd22",             # Yellow-green
  "Other" = "#7f7f7f"                   # Gray
)

# Create a color palette for phyla (will be generated dynamically based on phyla present)
# Using a color-blind friendly palette
get_phylum_colors <- function(phyla) {
  n_phyla <- length(phyla)
  if (n_phyla <= 15) {
    # Use a predefined palette for common numbers
    colors <- c("#e6194B", "#3cb44b", "#ffe119", "#4363d8", "#f58231", 
                "#911eb4", "#42d4f4", "#f032e6", "#bfef45", "#fabed4", 
                "#469990", "#dcbeff")
    color_map <- setNames(colors[1:n_phyla], phyla)
  } else {
    # Generate colors using rainbow palette for larger numbers
    color_map <- setNames(rainbow(n_phyla), phyla)
  }
  return(color_map)
}

