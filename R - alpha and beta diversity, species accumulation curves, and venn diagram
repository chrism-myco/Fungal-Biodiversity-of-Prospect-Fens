# Function to extract species list from phyloseq object
get_species_list <- function(physeq_obj, category_name) {
  # Get OTUs present in at least one sample
  present_otus <- taxa_sums(physeq_obj) > 0
  otu_ids <- taxa_names(physeq_obj)[present_otus]
  
  # Get taxonomy for these OTUs
  tax_table_subset <- as.data.frame(tax_table(physeq_obj)[otu_ids, ])
  
  # Create species identifier (use lowest available taxonomic level)
  species_list <- apply(tax_table_subset, 1, function(x) {
    # Find the last non-NA, non-empty taxonomic level
    valid <- x[!is.na(x) & x != "" & x != "unidentified"]
    if (length(valid) > 0) {
      return(tail(valid, 1))
    } else {
      return(NA)
    }
  })
  
  # Remove NAs and duplicates
  species_list <- unique(species_list[!is.na(species_list)])
  
  cat(paste0("\n", category_name, ": ", length(species_list), " unique taxa\n"))
  
  return(list(
    species = species_list,
    otu_ids = otu_ids,
    taxonomy = tax_table_subset
  ))
}

