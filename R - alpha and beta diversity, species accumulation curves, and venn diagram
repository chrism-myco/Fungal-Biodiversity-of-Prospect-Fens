library(biomformat)      # For reading BIOM files
library(phyloseq)        # For microbiome data analysis
library(vegan)           # For diversity calculations
library(ggplot2)         # For plotting
library(dplyr)           # For data manipulation
library(tidyr)           # For data reshaping
library(VennDiagram)     # For Venn diagrams
library(ape)             # For phylogenetic tree manipulation
library(ggtree)          # For phylogenetic tree visualization
library(gridExtra)       # For arranging multiple plots

# ==============================================================================
# 2. SET WORKING DIRECTORY AND FILE PATHS
# ==============================================================================

# Set your working directory where the files are located
# setwd("path/to/your/data")

# TROUBLESHOOTING: Check current directory and available files
cat("Current working directory:", getwd(), "\n")
cat("\nFiles in current directory:\n")
print(list.files())

# Define file paths
biom_file <- "data/OTU.biom"
taxonomy_file <- "data/taxonomy.txt"
phylo_file <- "data/OTUphylo.nwk"

# Check if files exist
cat("\n--- Checking for required files ---\n")
cat("OTU.biom exists:", file.exists(biom_file), "\n")
cat("taxonomy.txt exists:", file.exists(taxonomy_file), "\n")
cat("OTUphylo.nwk exists:", file.exists(phylo_file), "\n")

# ==============================================================================
# 3. IMPORT DATA FILES
# ==============================================================================

cat("Loading data files...\n")

# 3.1 Import BIOM file (contains OTU table and potentially metadata)
# LotuS2 can output different formats, so we'll try multiple approaches

# OPTION A: Try reading BIOM file
tryCatch({
  cat("Attempting to read BIOM file...\n")
  biom_data <- read_biom(biom_file)
  otu_table_data <- as(biom_data(biom_data), "matrix")
  cat("BIOM file loaded successfully!\n")
  biom_success <- TRUE
}, error = function(e) {
  cat("BIOM file import failed. Error:\n")
  print(e)
  cat("\nTrying alternative import methods...\n")
  biom_success <<- FALSE
})

# Check dimensions to determine orientation
cat("OTU table dimensions:", dim(otu_table_data), "\n")
cat("  Rows:", nrow(otu_table_data), "\n")
cat("  Columns:", ncol(otu_table_data), "\n")

# 3.2 Import taxonomy file
# Assuming taxonomy.txt is tab-delimited with OTU_ID and taxonomy columns
taxonomy_data <- read.table(taxonomy_file, 
                            header = TRUE, 
                            sep = "\t", 
                            comment.char = "",
                            quote = "",
                            stringsAsFactors = FALSE)

# 3.3 Import phylogenetic tree
phylo_tree <- read.tree(phylo_file)

# 3.4 Import sample metadata from external file
# User has provided metadata file with columns: SampleID, Peat, Vaccinium, Field ID
cat("\n--- Loading Sample Metadata ---\n")

metadata_files <- c("data/sample_metada.csv")

metadata_found <- FALSE
for (mfile in metadata_files) {
  if (file.exists(mfile)) {
    cat(paste0("Found metadata file: ", mfile, "\n"))
    
    # Determine separator based on file extension
    if (grepl(".csv$", mfile)) {
      sample_metadata <- read.table(mfile,
                                    header = TRUE,
                                    sep = ",",
                                    stringsAsFactors = FALSE,
                                    check.names = FALSE)
    } else {
      sample_metadata <- read.table(mfile,
                                    header = TRUE,
                                    sep = "\t",
                                    stringsAsFactors = FALSE,
                                    check.names = FALSE)
    }
    
    cat("Metadata loaded successfully!\n")
    cat("Columns found:", paste(colnames(sample_metadata), collapse = ", "), "\n")
    cat("Number of samples:", nrow(sample_metadata), "\n")
    metadata_found <- TRUE
    break
  }
}

if (!metadata_found) {
  stop("ERROR: Could not find metadata file. Please ensure one of these exists:\n",
       paste(metadata_files, collapse = ", "))
}

# Verify required columns exist
required_cols <- c("SampleID", "Peat", "Vaccinium")
missing_cols <- required_cols[!required_cols %in% colnames(sample_metadata)]
if (length(missing_cols) > 0) {
  stop("ERROR: Missing required columns in metadata: ", 
       paste(missing_cols, collapse = ", "))
}

# Check for Field ID column (case-insensitive)
field_id_col <- colnames(sample_metadata)[grepl("field.*id", colnames(sample_metadata), 
                                                ignore.case = TRUE)]
if (length(field_id_col) > 0) {
  cat("Field ID column found:", field_id_col[1], "\n")
  # Standardize column name
  colnames(sample_metadata)[colnames(sample_metadata) == field_id_col[1]] <- "FieldID"
} else {
  cat("Warning: No 'Field ID' column found. Using SampleID for labels.\n")
  sample_metadata$FieldID <- sample_metadata$SampleID
}

# Display metadata summary
cat("\nMetadata Summary:\n")
print(head(sample_metadata))
cat("\nPeat distribution:\n")
print(table(sample_metadata$Peat))
cat("\nVaccinium distribution:\n")
print(table(sample_metadata$Vaccinium))
cat("\n")

# Ensure SampleID matches OTU table sample names
otu_samples <- colnames(otu_table_data)
metadata_samples <- sample_metadata$SampleID

# Check for mismatches
if (!all(otu_samples %in% metadata_samples)) {
  cat("WARNING: Some OTU table samples not found in metadata:\n")
  missing <- otu_samples[!otu_samples %in% metadata_samples]
  cat(paste(missing, collapse = ", "), "\n")
}

if (!all(metadata_samples %in% otu_samples)) {
  cat("WARNING: Some metadata samples not found in OTU table:\n")
  missing <- metadata_samples[!metadata_samples %in% otu_samples]
  cat(paste(missing, collapse = ", "), "\n")
}

# Keep only samples present in both OTU table and metadata
common_samples <- intersect(otu_samples, metadata_samples)
cat(paste0("\nProceeding with ", length(common_samples), 
           " samples present in both OTU table and metadata\n"))

# Filter OTU table to matching samples
otu_table_data <- otu_table_data[, common_samples]

# Filter and order metadata to match OTU table
sample_metadata <- sample_metadata[match(common_samples, sample_metadata$SampleID), ]

# Convert logical to factor for analysis
sample_metadata$Peat <- as.factor(sample_metadata$Peat)
sample_metadata$Vaccinium <- as.factor(sample_metadata$Vaccinium)

# ==============================================================================
# 4. CREATE PHYLOSEQ OBJECT
# ==============================================================================

cat("Creating phyloseq object...\n")

# 4.1 Prepare OTU table for phyloseq
# Phyloseq expects OTUs as rows, samples as columns
if (nrow(otu_table_data) < ncol(otu_table_data)) {
  otu_table_data <- t(otu_table_data)
}

OTU <- otu_table(otu_table_data, taxa_are_rows = TRUE)

# 4.2 Prepare taxonomy table
# Parse taxonomy string into separate columns if needed
if (ncol(taxonomy_data) == 2) {
  # Assuming format: OTU_ID, taxonomy_string
  # Split taxonomy string (commonly separated by semicolons)
  tax_split <- strsplit(taxonomy_data[, 2], ";")
  
  # Determine maximum number of taxonomic levels
  max_levels <- max(sapply(tax_split, length))
  
  # Create matrix with taxonomic levels
  tax_matrix <- matrix(NA, nrow = nrow(taxonomy_data), ncol = max_levels)
  for (i in seq_along(tax_split)) {
    tax_matrix[i, 1:length(tax_split[[i]])] <- tax_split[[i]]
  }
  
  # Set column names (common taxonomic ranks for fungi)
  colnames(tax_matrix) <- c("Kingdom", "Phylum", "Class", "Order", 
                            "Family", "Genus", "Species")[1:max_levels]
  rownames(tax_matrix) <- taxonomy_data[, 1]
  
  TAX <- tax_table(tax_matrix)
} else {
  # Taxonomy already in matrix format
  tax_matrix <- as.matrix(taxonomy_data[, -1])
  rownames(tax_matrix) <- taxonomy_data[, 1]
  TAX <- tax_table(tax_matrix)
}

# 4.3 Prepare sample metadata
rownames(sample_metadata) <- sample_metadata$SampleID
SAMP <- sample_data(sample_metadata)

# 4.4 Prepare phylogenetic tree
TREE <- phy_tree(phylo_tree)

# 4.5 Combine into phyloseq object
physeq <- phyloseq(OTU, TAX, SAMP, TREE)

cat("Phyloseq object created successfully!\n")
print(physeq)

# ==============================================================================
# 5. DATA PREPROCESSING
# ==============================================================================

cat("\nPreprocessing data...\n")

# 5.1 Remove low-abundance OTUs (optional but recommended)
# Remove OTUs with less than 10 total reads across all samples
physeq_filtered <- prune_taxa(taxa_sums(physeq) >= 10, physeq)

cat("OTUs before filtering:", ntaxa(physeq), "\n")
cat("OTUs after filtering:", ntaxa(physeq_filtered), "\n")

# Use filtered data for downstream analysis
physeq <- physeq_filtered

# 5.2 Create presence/absence (occurrence) version
# Convert counts to presence/absence (0/1)
physeq_pa <- transform_sample_counts(physeq, function(x) ifelse(x > 0, 1, 0))

# ==============================================================================
# 6. SUBSET DATA BY METADATA CATEGORIES
# ==============================================================================

cat("\nSubsetting data by Peat and Vaccinium categories...\n")

# Create subsets for each condition
physeq_peat_true <- subset_samples(physeq, Peat == "TRUE")
physeq_peat_false <- subset_samples(physeq, Peat == "FALSE")
physeq_vacc_true <- subset_samples(physeq, Vaccinium == "TRUE")
physeq_vacc_false <- subset_samples(physeq, Vaccinium == "FALSE")

# Presence/absence versions
physeq_pa_peat_true <- subset_samples(physeq_pa, Peat == "TRUE")
physeq_pa_peat_false <- subset_samples(physeq_pa, Peat == "FALSE")
physeq_pa_vacc_true <- subset_samples(physeq_pa, Vaccinium == "TRUE")
physeq_pa_vacc_false <- subset_samples(physeq_pa, Vaccinium == "FALSE")

cat("Samples in Peat=TRUE:", nsamples(physeq_peat_true), "\n")
cat("Samples in Peat=FALSE:", nsamples(physeq_peat_false), "\n")
cat("Samples in Vaccinium=TRUE:", nsamples(physeq_vacc_true), "\n")
cat("Samples in Vaccinium=FALSE:", nsamples(physeq_vacc_false), "\n")

# ==============================================================================
# 7. ALPHA DIVERSITY ANALYSIS
# ==============================================================================

cat("\n========================================\n")
cat("ALPHA DIVERSITY ANALYSIS\n")
cat("========================================\n")

# 7.1 Species Accumulation Curves
cat("\n--- Species Accumulation Curves ---\n")

# Prepare OTU table in correct format for vegan (samples as rows, OTUs as columns)
cat("Preparing OTU matrix for accumulation curves...\n")
otu_matrix_t <- as.matrix(t(otu_table(physeq)))

# Verify dimensions
cat("Transposed OTU matrix dimensions: ", dim(otu_matrix_t), "\n")
cat("  Rows (samples):", nrow(otu_matrix_t), "\n")
cat("  Columns (OTUs):", ncol(otu_matrix_t), "\n")

  # 7.1.1 Overall species accumulation curve
  cat("Calculating overall species accumulation curve...\n")
  
  tryCatch({
    specaccum_overall <- specaccum(otu_matrix_t, method = "exact")
    
    # Plot overall accumulation curve
    png("species_accumulation_overall.png", width = 10, height = 8, units = "in", res = 300)
    plot(specaccum_overall, 
         ci.type = "poly", 
         col = "blue", 
         lwd = 2, 
         ci.lty = 0, 
         ci.col = alpha("lightblue", 0.5),
         xlab = "Number of Samples", 
         ylab = "Number of OTUs",
         main = "Species Accumulation Curve - All Samples",
         cex.main = 1.5,
         cex.lab = 1.2)
    grid()
    dev.off()
    
    cat("Overall curve: Observed OTUs =", max(specaccum_overall$richness), "\n")
    cat("Expected at", specaccum_overall$sites[length(specaccum_overall$sites)], 
        "samples:", round(specaccum_overall$richness[length(specaccum_overall$richness)]), "\n")
    
  }, error = function(e) {
    cat("ERROR creating overall accumulation curve:\n")
    print(e)
    cat("This may be due to insufficient data or matrix format issues.\n")
    specaccum_overall <<- NULL
  })
  
  # 7.1.2 Species accumulation by Peat
  cat("\nCalculating species accumulation curves by Peat...\n")
  
  # Split samples by Peat
  samples_peat_true <- sample_metadata$SampleID[sample_metadata$Peat == "TRUE"]
  samples_peat_false <- sample_metadata$SampleID[sample_metadata$Peat == "FALSE"]
  
  cat("Samples with Peat=TRUE:", length(samples_peat_true), "\n")
  cat("Samples with Peat=FALSE:", length(samples_peat_false), "\n")
  
  # Only proceed if we have samples in each category
  if (length(samples_peat_true) >= 2 && length(samples_peat_false) >= 2) {
    
    tryCatch({
      # Subset OTU matrix
      otu_peat_true <- otu_matrix_t[rownames(otu_matrix_t) %in% samples_peat_true, ]
      otu_peat_false <- otu_matrix_t[rownames(otu_matrix_t) %in% samples_peat_false, ]
      
      # Remove OTUs not present in these samples
      otu_peat_true <- otu_peat_true[, colSums(otu_peat_true) > 0]
      otu_peat_false <- otu_peat_false[, colSums(otu_peat_false) > 0]
      
      # Calculate accumulation curves
      specaccum_peat_true <- specaccum(otu_peat_true, method = "exact")
      specaccum_peat_false <- specaccum(otu_peat_false, method = "exact")
      
      # Plot Peat comparison
      png("species_accumulation_Peat.png", width = 12, height = 8, units = "in", res = 300)
      plot(specaccum_peat_true, 
           ci.type = "poly", 
           col = "#E41A1C", 
           lwd = 2, 
           ci.lty = 0, 
           ci.col = alpha("#E41A1C", 0.3),
           xlab = "Number of Samples", 
           ylab = "Number of OTUs",
           main = "Species Accumulation Curves by Peat",
           cex.main = 1.5,
           cex.lab = 1.2,
           ylim = c(0, max(c(specaccum_peat_true$richness, specaccum_peat_false$richness)) * 1.1))
      plot(specaccum_peat_false, 
           ci.type = "poly", 
           col = "#377EB8", 
           lwd = 2, 
           ci.lty = 0, 
           ci.col = alpha("#377EB8", 0.3),
           add = TRUE)
      legend("bottomright", 
             legend = c("Peat = TRUE", "Peat = FALSE"), 
             col = c("#E41A1C", "#377EB8"), 
             lwd = 2, 
             bty = "n",
             cex = 1.2)
      grid()
      dev.off()
      
      cat("Peat=TRUE: Observed OTUs =", max(specaccum_peat_true$richness), "\n")
      cat("Peat=FALSE: Observed OTUs =", max(specaccum_peat_false$richness), "\n")
      
    }, error = function(e) {
      cat("ERROR creating Peat accumulation curves:\n")
      print(e)
      specaccum_peat_true <<- NULL
      specaccum_peat_false <<- NULL
    })
    
  } else {
    cat("Insufficient samples for Peat comparison (need at least 2 per category)\n")
    specaccum_peat_true <- NULL
    specaccum_peat_false <- NULL
  }
  
  # 7.1.3 Species accumulation by Vaccinium
  cat("\nCalculating species accumulation curves by Vaccinium...\n")
  
  samples_vacc_true <- sample_metadata$SampleID[sample_metadata$Vaccinium == "TRUE"]
  samples_vacc_false <- sample_metadata$SampleID[sample_metadata$Vaccinium == "FALSE"]
  
  cat("Samples with Vaccinium=TRUE:", length(samples_vacc_true), "\n")
  cat("Samples with Vaccinium=FALSE:", length(samples_vacc_false), "\n")
  
  if (length(samples_vacc_true) >= 2 && length(samples_vacc_false) >= 2) {
    
    tryCatch({
      otu_vacc_true <- otu_matrix_t[rownames(otu_matrix_t) %in% samples_vacc_true, ]
      otu_vacc_false <- otu_matrix_t[rownames(otu_matrix_t) %in% samples_vacc_false, ]
      
      # Remove OTUs not present in these samples
      otu_vacc_true <- otu_vacc_true[, colSums(otu_vacc_true) > 0]
      otu_vacc_false <- otu_vacc_false[, colSums(otu_vacc_false) > 0]
      
      specaccum_vacc_true <- specaccum(otu_vacc_true, method = "exact")
      specaccum_vacc_false <- specaccum(otu_vacc_false, method = "exact")
      
      # Plot Vaccinium comparison
      png("species_accumulation_Vaccinium.png", width = 12, height = 8, units = "in", res = 300)
      plot(specaccum_vacc_true, 
           ci.type = "poly", 
           col = "#4DAF4A", 
           lwd = 2, 
           ci.lty = 0, 
           ci.col = alpha("#4DAF4A", 0.3),
           xlab = "Number of Samples", 
           ylab = "Number of OTUs",
           main = "Species Accumulation Curves by Vaccinium",
           cex.main = 1.5,
           cex.lab = 1.2,
           ylim = c(0, max(c(specaccum_vacc_true$richness, specaccum_vacc_false$richness)) * 1.1))
      plot(specaccum_vacc_false, 
           ci.type = "poly", 
           col = "#984EA3", 
           lwd = 2, 
           ci.lty = 0, 
           ci.col = alpha("#984EA3", 0.3),
           add = TRUE)
      legend("bottomright", 
             legend = c("Vaccinium = TRUE", "Vaccinium = FALSE"), 
             col = c("#4DAF4A", "#984EA3"), 
             lwd = 2, 
             bty = "n",
             cex = 1.2)
      grid()
      dev.off()
      
      cat("Vaccinium=TRUE: Observed OTUs =", max(specaccum_vacc_true$richness), "\n")
      cat("Vaccinium=FALSE: Observed OTUs =", max(specaccum_vacc_false$richness), "\n")
      
    }, error = function(e) {
      cat("ERROR creating Vaccinium accumulation curves:\n")
      print(e)
      specaccum_vacc_true <<- NULL
      specaccum_vacc_false <<- NULL
    })
    
  } else {
    cat("Insufficient samples for Vaccinium comparison (need at least 2 per category)\n")
    specaccum_vacc_true <- NULL
    specaccum_vacc_false <- NULL
  }
  
  # 7.1.4 Species accumulation for all four combinations
  cat("\nCalculating species accumulation for all four category combinations...\n")
  
  samples_PT_VT <- sample_metadata$SampleID[sample_metadata$Peat == "TRUE" & 
                                              sample_metadata$Vaccinium == "TRUE"]
  samples_PT_VF <- sample_metadata$SampleID[sample_metadata$Peat == "TRUE" & 
                                              sample_metadata$Vaccinium == "FALSE"]
  samples_PF_VT <- sample_metadata$SampleID[sample_metadata$Peat == "FALSE" & 
                                              sample_metadata$Vaccinium == "TRUE"]
  samples_PF_VF <- sample_metadata$SampleID[sample_metadata$Peat == "FALSE" & 
                                              sample_metadata$Vaccinium == "FALSE"]
  
  # Calculate accumulation curves (only if samples exist in each category)
  if (length(samples_PT_VT) > 0) {
    specaccum_PT_VT <- specaccum(otu_matrix_t[samples_PT_VT, ], method = "exact")
  } else {
    specaccum_PT_VT <- NULL
  }
  
  if (length(samples_PT_VF) > 0) {
    specaccum_PT_VF <- specaccum(otu_matrix_t[samples_PT_VF, ], method = "exact")
  } else {
    specaccum_PT_VF <- NULL
  }
  
  if (length(samples_PF_VT) > 0) {
    specaccum_PF_VT <- specaccum(otu_matrix_t[samples_PF_VT, ], method = "exact")
  } else {
    specaccum_PF_VT <- NULL
  }
  
  if (length(samples_PF_VF) > 0) {
    specaccum_PF_VF <- specaccum(otu_matrix_t[samples_PF_VF, ], method = "exact")
  } else {
    specaccum_PF_VF <- NULL
  }
  
  # Plot all four combinations
  png("species_accumulation_fourway.png", width = 14, height = 10, units = "in", res = 300)
  par(mar = c(5, 5, 4, 2))
  
  # Determine y-axis limits
  all_max <- max(c(
    if (!is.null(specaccum_PT_VT)) max(specaccum_PT_VT$richness) else 0,
    if (!is.null(specaccum_PT_VF)) max(specaccum_PT_VF$richness) else 0,
    if (!is.null(specaccum_PF_VT)) max(specaccum_PF_VT$richness) else 0,
    if (!is.null(specaccum_PF_VF)) max(specaccum_PF_VF$richness) else 0
  ))
  
  # Initialize plot
  plot(1, type = "n", 
       xlim = c(0, max(c(length(samples_PT_VT), length(samples_PT_VF), 
                         length(samples_PF_VT), length(samples_PF_VF)))),
       ylim = c(0, all_max * 1.1),
       xlab = "Number of Samples", 
       ylab = "Number of OTUs",
       main = "Species Accumulation Curves - All Category Combinations",
       cex.main = 1.5,
       cex.lab = 1.2)
  grid()
  
  # Add curves
  colors <- c("#E41A1C", "#377EB8", "#4DAF4A", "#984EA3")
  labels <- c("Peat=T, Vacc=T", "Peat=T, Vacc=F", "Peat=F, Vacc=T", "Peat=F, Vacc=F")
  active_curves <- c(!is.null(specaccum_PT_VT), !is.null(specaccum_PT_VF),
                     !is.null(specaccum_PF_VT), !is.null(specaccum_PF_VF))
  
  if (!is.null(specaccum_PT_VT)) {
    plot(specaccum_PT_VT, ci.type = "poly", col = colors[1], lwd = 2, 
         ci.lty = 0, ci.col = alpha(colors[1], 0.3), add = TRUE)
  }
  if (!is.null(specaccum_PT_VF)) {
    plot(specaccum_PT_VF, ci.type = "poly", col = colors[2], lwd = 2, 
         ci.lty = 0, ci.col = alpha(colors[2], 0.3), add = TRUE)
  }
  if (!is.null(specaccum_PF_VT)) {
    plot(specaccum_PF_VT, ci.type = "poly", col = colors[3], lwd = 2, 
         ci.lty = 0, ci.col = alpha(colors[3], 0.3), add = TRUE)
  }
  if (!is.null(specaccum_PF_VF)) {
    plot(specaccum_PF_VF, ci.type = "poly", col = colors[4], lwd = 2, 
         ci.lty = 0, ci.col = alpha(colors[4], 0.3), add = TRUE)
  }
  
  legend("bottomright", 
         legend = labels[active_curves], 
         col = colors[active_curves], 
         lwd = 2, 
         bty = "n",
         cex = 1.1)
  dev.off()
  
  # Print summary statistics
  cat("\nFour-way accumulation summary:\n")
  if (!is.null(specaccum_PT_VT)) {
    cat("Peat=T, Vacc=T: ", length(samples_PT_VT), " samples, ", 
        max(specaccum_PT_VT$richness), " OTUs\n", sep = "")
  }
  if (!is.null(specaccum_PT_VF)) {
    cat("Peat=T, Vacc=F: ", length(samples_PT_VF), " samples, ", 
        max(specaccum_PT_VF$richness), " OTUs\n", sep = "")
  }
  if (!is.null(specaccum_PF_VT)) {
    cat("Peat=F, Vacc=T: ", length(samples_PF_VT), " samples, ", 
        max(specaccum_PF_VT$richness), " OTUs\n", sep = "")
  }
  if (!is.null(specaccum_PF_VF)) {
    cat("Peat=F, Vacc=F: ", length(samples_PF_VF), " samples, ", 
        max(specaccum_PF_VF$richness), " OTUs\n", sep = "")
  }
  
  # 7.1.5 Rarefaction curves (alternative visualization) ##### ERRORRRR #####
  cat("\nGenerating rarefaction curves...\n")
  
  # Rarefaction shows species richness as a function of sequencing depth
  rarecurve_data <- rarecurve(otu_matrix_t, step = 100, label = FALSE)
  
  png("rarefaction_curves.png", width = 12, height = 8, units = "in", res = 300)
  rarecurve(otu_matrix_t, 
            step = 100, 
            col = "blue", 
            lwd = 1.5,
            xlab = "Sample Size (Number of Sequences)", 
            ylab = "Number of OTUs",
            main = "Rarefaction Curves - All Samples",
            cex.main = 1.5,
            cex.lab = 1.2)
  grid()
  dev.off()
  
  # 7.1.6 Export accumulation data to CSV
  cat("Exporting species accumulation data...\n")
  
  # Overall accumulation
  accumulation_overall <- data.frame(
    Samples = specaccum_overall$sites,
    Richness = specaccum_overall$richness,
    SD = specaccum_overall$sd
  )
  write.csv(accumulation_overall, "species_accumulation_overall.csv", row.names = FALSE)
  
  # By Peat
  if (!is.null(specaccum_peat_true)) {
    accumulation_peat_true <- data.frame(
      Samples = specaccum_peat_true$sites,
      Richness = specaccum_peat_true$richness,
      SD = specaccum_peat_true$sd
    )
    write.csv(accumulation_peat_true, "species_accumulation_Peat_TRUE.csv", row.names = FALSE)
  }
  
  if (!is.null(specaccum_peat_false)) {
    accumulation_peat_false <- data.frame(
      Samples = specaccum_peat_false$sites,
      Richness = specaccum_peat_false$richness,
      SD = specaccum_peat_false$sd
    )
    write.csv(accumulation_peat_false, "species_accumulation_Peat_FALSE.csv", row.names = FALSE)
  }
  
  # By Vaccinium
  if (!is.null(specaccum_vacc_true)) {
    accumulation_vacc_true <- data.frame(
