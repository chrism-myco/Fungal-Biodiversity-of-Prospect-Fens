# 11.2 Create tip labels with last known taxonomy
# Function to get the most specific taxonomic assignment
get_last_taxonomy <- function(tax_row) {
  # Get all non-NA, non-empty values
  valid_tax <- tax_row[!is.na(tax_row) & tax_row != "" & 
                         tax_row != "unidentified" & 
                         tax_row != "uncultured"]
  
  if (length(valid_tax) == 0) {
    return("Unclassified")
  }
  
  # Return the last valid taxonomic level
  last_tax <- tail(valid_tax, 1)
  
  # If we have genus or species, format nicely
  if (length(valid_tax) >= 2) {
    # Get the rank name (genus, species, etc.)
    rank_name <- names(tail(valid_tax, 1))
    return(paste0(last_tax, " (", rank_name, ")"))
  }
  
  return(as.character(last_tax))
}

