# 11.6 Tree with taxonomy color coding by phylum
cat("Creating taxonomy-colored phylogenetic tree...\n")

# Add phylum information to tree data
tree_data <- data.frame(
  OTU = taxa_names(physeq),
  Phylum = as.character(tax_table(physeq)[, "Phylum"])
)
tree_data$Phylum[is.na(tree_data$Phylum)] <- "Unclassified"

# Create color palette for phyla
n_phyla <- length(unique(tree_data$Phylum))
phylum_colors <- rainbow(n_phyla)
names(phylum_colors) <- unique(tree_data$Phylum)

# Match tree tips to phylum data
tip_phyla <- tree_data$Phylum[match(names(tip_labels), tree_data$OTU)]

p_tree_colored <- ggtree(tree, layout = "rectangular", ladderize = TRUE) %<+% 
  tree_data +
  geom_tiplab(aes(color = Phylum), size = 2, align = FALSE) +
  scale_color_manual(values = phylum_colors) +
  geom_treescale(x = 0, y = -5, width = 0.1, fontsize = 3) +
  theme_tree2() +
  labs(title = "Phylogenetic Tree Colored by Phylum",
       subtitle = "Tips labeled with lowest known taxonomic classification") +
  theme(plot.title = element_text(size = 16, face = "bold", hjust = 0.5),
        plot.subtitle = element_text(size = 12, hjust = 0.5),
        legend.position = "right",
        legend.title = element_text(size = 12, face = "bold"),
        legend.text = element_text(size = 10))

ggsave("phylogenetic_tree_colored.png", 
       plot = p_tree_colored, 
       width = 16, 
       height = max(20, ntaxa(physeq) * 0.15), 
       units = "cm", 
       dpi = 300,
       limitsize = FALSE)

